# Reference values only: Handoff Forge does not auto-load this file.
# Export only the variables you need or pass them through your process/container runtime.
# Handoff Forge is offline and local-only unless both flags are explicitly enabled.
HANDOFF_FORGE_OFFLINE=true
HANDOFF_FORGE_ALLOW_NETWORK=false
HANDOFF_FORGE_DATA_DIR=.data

# Optional provider key names. Leave unset for the complete offline workflow.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# XAI_API_KEY=
# VOYAGE_API_KEY=
